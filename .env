DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sushil_COZ123
DB_NAME=people's_priority
SCHEDULER_TIME=23:30

# ── Layer 2 media processing ────────────────────────────────────────────────
# Path to the backend's uploads folder (where citizen audio/image files live).
# Leave blank to auto-resolve to ../coz_code_backend/uploads
UPLOAD_BASE_DIR=

# ffmpeg/ffprobe (needed by pydub for audio format conversion). Leave blank to
# auto-detect from PATH. Set explicitly if ffmpeg is not on PATH.
FFMPEG_PATH=D:\MOM Transcripts\ffmpeg-n7.1-latest-win64-gpl-7.1\ffmpeg-n7.1-latest-win64-gpl-7.1\bin\ffmpeg.exe
FFPROBE_PATH=D:\MOM Transcripts\ffmpeg-n7.1-latest-win64-gpl-7.1\ffmpeg-n7.1-latest-win64-gpl-7.1\bin\ffprobe.exe

# ── Google services mode ────────────────────────────────────────────────────
# dev   = free/offline stand-ins, no GCP creds (free Google ASR/Translate web
#         endpoints + local fastembed embeddings). Good for local/hackathon.
# cloud = official GCP APIs via a service account (Cloud Speech-to-Text,
#         Cloud Translation, Vertex AI embeddings). Use in production on GCP.
GOOGLE_MODE=dev

# ── Google Cloud Vision (OCR for image → text, incl. Hindi/Odia) ────────────
# Paste your Google Cloud Vision API key here (REST API key, not a service acct).
# Used in BOTH modes (Vision is called over REST).
GOOGLE_VISION_API_KEY=

# ── GCP (only needed when GOOGLE_MODE=cloud) ────────────────────────────────
# Path to a service-account JSON with Speech, Translation & Vertex AI access.
GOOGLE_APPLICATION_CREDENTIALS=
GCP_PROJECT=
GCP_LOCATION=us-central1

# Embedding models (semantic clustering, Layer 3)
EMBEDDING_MODEL_DEV=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_MODEL_CLOUD=text-multilingual-embedding-002
